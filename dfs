from concurrent.futures import ThreadPoolExecutor
import threading

class Graph:
    def __init__(self, V):
        self.V = V
        self.adj = [[] for _ in range(V)]

    # Add edge
    def add_edge(self, u, v):
        self.adj[u].append(v)
        self.adj[v].append(u)

    # DFS Utility
    def dfs_util(self, node, visited, lock):

        with lock:
            if visited[node]:
                return

            visited[node] = True
            print(node, end=" ")

        # Process neighbors sequentially
        for neighbor in self.adj[node]:

            if not visited[neighbor]:

                # Create thread for recursive DFS
                with ThreadPoolExecutor(max_workers=1) as executor:
                    future = executor.submit(
                        self.dfs_util,
                        neighbor,
                        visited,
                        lock
                    )

                    future.result()

    # Parallel DFS
    def parallel_dfs(self, start):

        visited = [False] * self.V

        lock = threading.Lock()

        print("Parallel DFS Traversal:", end=" ")

        self.dfs_util(start, visited, lock)

        print()


# Main Program
V = int(input("Enter number of vertices: "))

g = Graph(V)

E = int(input("Enter number of edges: "))

print("Enter edges (u v):")

for _ in range(E):
    u, v = map(int, input().split())
    g.add_edge(u, v)

start = int(input("Enter starting vertex: "))

g.parallel_dfs(start)
